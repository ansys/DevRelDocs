{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Ansys developer portal",
  "description": "Developer documentation for Ansys products — APIs, libraries, and guides.",
  "colors": {
    "primary": "#FFB71B",
    "light": "#FFB71B",
    "dark": "#cc0000"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "$ref": "./navigation/main.json"
  },
  "redirects": {
    "$ref": "./navigation/redirects.json"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Forum",
        "href": "https://discuss.ansys.com/"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Documentation",
      "href": "/docs/index"
    }
  }
}
