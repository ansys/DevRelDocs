{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Ansys developer portal",
  "description": "Developer documentation for Ansys products — APIs, libraries, and guides.",
  "colors": {
    "primary": "#FFB71B",
    "light": "#ff4d4d",
    "dark": "#cc0000"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "$ref": "./navigation/main.json"
  },
  "redirects": {
    "$ref": "./navigation/redirects.json"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Production portal",
